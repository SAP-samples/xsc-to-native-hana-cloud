 VIEW "sap.hana.democontent.epm.data::MD.productTexts" ( "PRODUCTID", "CATEGORY", "TEXT" ) AS SELECT "A_$0"."PRODUCTID" ,
 "A_$0"."CATEGORY" ,
 "texts_$1"."TEXT" FROM  ( "sap.hana.democontent.epm.data::MD.Products" AS "A_$0" LEFT OUTER JOIN "sap.hana.democontent.epm.data::MD.texts" AS "texts_$1" ON  ( "A_$0"."NAMEID" = "texts_$1"."TEXTID" )  ) WITH READ ONLY