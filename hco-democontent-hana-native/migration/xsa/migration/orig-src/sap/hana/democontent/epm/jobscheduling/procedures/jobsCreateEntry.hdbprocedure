PROCEDURE "SAP_HANA_DEMO"."sap.hana.democontent.epm.jobscheduling.procedures::jobsCreateEntry" (IN DESCRIPTION NVARCHAR(30)) 
	LANGUAGE SQLSCRIPT
	SQL SECURITY INVOKER 
	DEFAULT SCHEMA SAP_HANA_DEMO
	AS
BEGIN 

declare DESCNAME string;
DESCNAME := DESCRIPTION;

/*This Procedure inserts a record with the current timestamp into the "JobsDemo" table*/

   insert into "sap.hana.democontent.epm.data::JobsDemo.Details" 
             values (now(), DESCNAME);

END;