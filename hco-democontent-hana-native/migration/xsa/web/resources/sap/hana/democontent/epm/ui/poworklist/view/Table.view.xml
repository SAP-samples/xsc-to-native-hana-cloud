<sap.ui.core.mvc:View controllerName="shine.democontent.epm.poworklist.view.Table"
    xmlns:sap.ui.table="sap.ui.table"
    xmlns:sap.ui.commons="sap.ui.commons"
    xmlns:sap.ui.core="sap.ui.core"
    xmlns:sap.ui.core.mvc="sap.ui.core.mvc"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
    <sap.ui.table:Table id="poTable" visibleRowCount="6" selectionMode="Single" selectionBehavior="Row" navigationMode="Paginator" rows="{/PO_WORKLIST}" rowSelectionChange="onRowSelectionChange">
        <sap.ui.table:toolbar>
            <sap.ui.commons:Toolbar id="tb1" design="Standard" standalone="false">
                <sap.ui.commons:items>
                    <sap.ui.commons:Button id="btnNew" text="{i18n>new}" tooltip="{i18n>create}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:Button id="btnEdit" text="{i18n>edit}" tooltip="{i18n>t_edit}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:Button id="btnDelete" text="{i18n>delete}" tooltip="{i18n>t_delete}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:MenuButton id="btnMenu" text="{i18n>actions}" tooltip="{i18n>t_actions}" itemSelected = "onMenuSelected">
                        <sap.ui.commons:menu>
                            <sap.ui.commons:Menu id="menuTB">
                                <sap.ui.commons:items>
                                    <sap.ui.commons:MenuItem id="itemAccept" text="{i18n>accept}"></sap.ui.commons:MenuItem>
                                    <sap.ui.commons:MenuItem id="itemReject" text="{i18n>reject}"></sap.ui.commons:MenuItem>
                                </sap.ui.commons:items>
                            </sap.ui.commons:Menu>
                        </sap.ui.commons:menu>
                    </sap.ui.commons:MenuButton>
                    <sap.ui.commons:ToolbarSeparator design="Standard"></sap.ui.commons:ToolbarSeparator>
                    <sap.ui.commons:Button id="btnExcel" text="{i18n>excel}" tooltip="{i18n>t_excel}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:Button id="btnZip" text="{i18n>zip}" tooltip="{i18n>t_zip}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:Button id="btnConv" text="{i18n>conversion}" tooltip="{i18n>t_t_conversion}" press="onTBPress"></sap.ui.commons:Button>
                    <sap.ui.commons:Button class="helpButton" text="?" data:tileDialog="2" press="openTileDialog"></sap.ui.commons:Button>
                </sap.ui.commons:items>
            </sap.ui.commons:Toolbar>
        </sap.ui.table:toolbar>
        <sap.ui.table:columns>
            <sap.ui.table:Column sortProperty="PURCHASEORDERID" filterProperty="PURCHASEORDERID" filterOperator="EQ">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>spoid}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{PURCHASEORDERID}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column width="125px" sortProperty="PURCHASEORDERITEM" filterProperty="PURCHASEORDERITEM">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>item}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{PURCHASEORDERITEM}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="PARTNERID" filterProperty="PARTNERID">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>bpart}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{PARTNERID}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="PRODUCTID" filterProperty="PRODUCTID">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>product}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{PRODUCTID}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="COMPANYNAME" filterProperty="COMPANYNAME">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>company}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{COMPANYNAME}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column hAlign="End" sortProperty="GROSSAMOUNT">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>gross}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{path:'GROSSAMOUNT',formatter:'.numericFormatter'}" textAlign="End"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="CURRENCY" filterProperty="CURRENCY">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>currency}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{path:'CURRENCY',formatter:'.currencyNameConverter'}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="LIFECYCLEDESC" filterProperty="LIFECYCLEDESC">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>lifecycle}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{LIFECYCLEDESC}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="APPROVALDESC" filterProperty="APPROVALDESC">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>approval}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{APPROVALDESC}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="CONFIRMDESC" filterProperty="CONFIRMDESC">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>confirm}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{CONFIRMDESC}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
            <sap.ui.table:Column sortProperty="ORDERINGDESCC" filterProperty="ORDERINGDESC">
                <sap.ui.table:label>
                    <sap.ui.commons:Label text="{i18n>ordering}" requiredAtBegin="false"></sap.ui.commons:Label>
                </sap.ui.table:label>
                <sap.ui.table:template>
                    <sap.ui.commons:TextView text="{ORDERINGDESC}"></sap.ui.commons:TextView>
                </sap.ui.table:template>
            </sap.ui.table:Column>
        </sap.ui.table:columns>
    </sap.ui.table:Table>
</sap.ui.core.mvc:View>  