 VIEW "sap.hana.democontent.epm.data::Util.AttachementsView" ( "NOTEID", "Type", "Title", "CREATEDAT", "Description", "Size", "LINKID" ) AS SELECT "Attachments_$0"."NOTEID" ,
 "Attachments_$0"."TYPE" AS "Type" ,
 "Attachments_$0"."TITLE" AS "Title" ,
 "Attachments_$0"."CREATEDAT" ,
 "Attachments_$0"."DESCRIPTION" AS "Description" ,
 "Attachments_$0"."SIZE" AS "Size" ,
 "Attachments_$0"."LINKID" FROM "sap.hana.democontent.epm.data::Util.Attachments" AS "Attachments_$0"