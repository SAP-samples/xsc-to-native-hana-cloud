 COLUMN TABLE "sap.hana.democontent.epm.data::Util.Messages"(
"MESSAGECLASS" NVARCHAR(20) NOT NULL ,
 "MESSAGENUMBER" NVARCHAR(3) NOT NULL ,
 "LANGUAGE" NVARCHAR(2) NOT NULL ,
 "DESCRIPTION" NVARCHAR(255),
 "TEXT" NCLOB,
 PRIMARY KEY ("MESSAGECLASS", "MESSAGENUMBER", "LANGUAGE")
) UNLOAD PRIORITY 5  AUTO MERGE